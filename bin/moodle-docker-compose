#!/usr/bin/env bash
set -e

# ===========================================================
# Moodle Docker helper script (macOS + Docker Compose v2)
# ===========================================================

# Determine real path of this script
thisfile=$( readlink "${BASH_SOURCE[0]}" ) || thisfile="${BASH_SOURCE[0]}"
basedir="$( cd "$( dirname "$thisfile" )/../" && pwd -P )"

# Check required environment variables
if [ ! -d "$MOODLE_DOCKER_WWWROOT" ]; then
    echo 'Error: $MOODLE_DOCKER_WWWROOT is not set or not an existing directory'
    exit 1
fi

if [ -z "$MOODLE_DOCKER_DB" ]; then
    echo 'Error: $MOODLE_DOCKER_DB is not set'
    exit 1
fi

export ASSETDIR="${basedir}/assets"

# ----------------------------
# Docker Compose detection
# ----------------------------
if docker compose version > /dev/null 2>&1; then
    dockercompose=(docker compose)
else
    dockercompose=(docker-compose)
fi

# ----------------------------
# Base compose files
# ----------------------------
dockercompose+=(-f "${basedir}/base.yml")
dockercompose+=(-f "${basedir}/service.mail.yml")

# PHP version
export MOODLE_DOCKER_PHP_VERSION=${MOODLE_DOCKER_PHP_VERSION:-8.3}

# Database file
dockercompose+=(-f "${basedir}/db.${MOODLE_DOCKER_DB}.yml")

# Optional DB version
if [ ! -z "$MOODLE_DOCKER_DB_VERSION" ]; then
    filename="${basedir}/db.${MOODLE_DOCKER_DB}.${MOODLE_DOCKER_DB_VERSION}.yml"
    if [ -f "$filename" ]; then
        dockercompose+=(-f "$filename")
    fi
fi

# Optional DB port override
if [[ $MOODLE_DOCKER_DB_PORT == *":"* ]] || [[ $MOODLE_DOCKER_DB_PORT -gt 0 ]]; then
    if [[ ! $MOODLE_DOCKER_DB_PORT == *":"* ]]; then
        export MOODLE_DOCKER_DB_PORT=127.0.0.1:$MOODLE_DOCKER_DB_PORT
    fi
    filename="${basedir}/db.${MOODLE_DOCKER_DB}.port.yml"
    if [ -f "$filename" ]; then
        dockercompose+=(-f "$filename")
    fi
fi

# ----------------------------
# Mobile app runtime detection
# ----------------------------
if [ -z "$MOODLE_DOCKER_APP_RUNTIME" ]; then
    if [[ ! -z "$MOODLE_DOCKER_APP_PATH" ]]; then
        appversion="$(cat $MOODLE_DOCKER_APP_PATH/package.json | sed -n -E 's/\s*"version": "([0-9]+\.[0-9]+\.[0-9]+)(.*)?",/\1/p')"
    elif [[ ! -z "$MOODLE_DOCKER_APP_VERSION" ]]; then
        appversion=$MOODLE_DOCKER_APP_VERSION
    fi

    if [[ ! -z $appversion ]]; then
        appmajorversion=$(echo $appversion | cut -d. -f1)
        appminorversion=$(echo $appversion | cut -d. -f2)

        if (( appmajorversion > 4 || appminorversion > 3 )); then
            export MOODLE_DOCKER_APP_RUNTIME="ionic7"
        else
            export MOODLE_DOCKER_APP_RUNTIME="ionic5"
        fi
    fi
fi

# Node version for mobile app
if [[ -z "$MOODLE_DOCKER_APP_NODE_VERSION" ]] && [[ ! -z "$MOODLE_DOCKER_APP_PATH" ]]; then
    appnodeversion="$(cat $MOODLE_DOCKER_APP_PATH/.nvmrc | sed -E "s/v(([0-9]+\.?)+)/\1/" || true)"
    appnodeversion="${appnodeversion//\//-}"
    export MOODLE_DOCKER_APP_NODE_VERSION="$appnodeversion"
fi

# Mobile app port & protocol
export MOODLE_DOCKER_APP_PORT=${MOODLE_DOCKER_APP_PORT:-${MOODLE_DOCKER_APP_RUNTIME=="ionic5" && echo 80 || echo 443}}
export MOODLE_DOCKER_APP_PROTOCOL=${MOODLE_DOCKER_APP_PROTOCOL:-${MOODLE_DOCKER_APP_RUNTIME=="ionic5" && echo http || echo https}}

# ----------------------------
# Selenium browser detection
# ----------------------------
browserparts=(${MOODLE_DOCKER_BROWSER//:/ })
export MOODLE_DOCKER_BROWSER_NAME=${browserparts[0]:-firefox}
export MOODLE_DOCKER_BROWSER_TAG=${browserparts[1]:-4}

if [[ "$MOODLE_DOCKER_BROWSER_NAME" == "chrome" ]]; then
    if [[ ! -z "$MOODLE_DOCKER_APP_PATH" ]]; then
        dockercompose+=(-f "${basedir}/moodle-app-dev.yml")
    elif [[ ! -z "$MOODLE_DOCKER_APP_VERSION" ]]; then
        dockercompose+=(-f "${basedir}/moodle-app.yml")
    fi
fi

if [[ "$MOODLE_DOCKER_BROWSER_NAME" != "firefox" ]]; then
    dockercompose+=(-f "${basedir}/selenium.${MOODLE_DOCKER_BROWSER_NAME}.yml")
fi

# Selenium VNC port
if [[ $MOODLE_DOCKER_SELENIUM_VNC_PORT == *":"* ]] || [[ $MOODLE_DOCKER_SELENIUM_VNC_PORT -gt 0 ]]; then
    if [[ $(echo $MOODLE_DOCKER_BROWSER_TAG | sed 's/[^0-9].*//g') -lt 4 ]]; then
        export MOODLE_DOCKER_SELENIUM_SUFFIX="-debug"
    fi
    if [[ ! $MOODLE_DOCKER_SELENIUM_VNC_PORT == *":"* ]]; then
        MOODLE_DOCKER_SELENIUM_VNC_PORT=127.0.0.1:$MOODLE_DOCKER_SELENIUM_VNC_PORT
    fi
    dockercompose+=(-f "${basedir}/selenium.debug.yml")
fi

# Optional external services, mocks, ML backend
[[ ! -z "$MOODLE_DOCKER_PHPUNIT_EXTERNAL_SERVICES" ]] && dockercompose+=(-f "${basedir}/phpunit-external-services.yml")
[[ ! -z "$MOODLE_DOCKER_BBB_MOCK" ]] && dockercompose+=(-f "${basedir}/bbb-mock.yml")
[[ ! -z "$MOODLE_DOCKER_MATRIX_MOCK" ]] && dockercompose+=(-f "${basedir}/matrix-mock.yml")
[[ ! -z "$MOODLE_DOCKER_MLBACKEND" ]] && dockercompose+=(-f "${basedir}/mlbackend.yml")

# Faildump
if [[ ! -z "$MOODLE_DOCKER_BEHAT_FAILDUMP" ]]; then
    if [ ! -d "$MOODLE_DOCKER_BEHAT_FAILDUMP" ]; then
        echo 'Error: $MOODLE_DOCKER_BEHAT_FAILDUMP is not an existing directory'
        exit 1
    fi
    dockercompose+=(-f "${basedir}/behat-faildump.yml")
fi

# Webserver
export MOODLE_DOCKER_WEB_HOST=${MOODLE_DOCKER_WEB_HOST:-localhost}
export MOODLE_DOCKER_WEB_PORT=${MOODLE_DOCKER_WEB_PORT:-8000}
if [[ $MOODLE_DOCKER_WEB_PORT == *":"* ]] || [[ $MOODLE_DOCKER_WEB_PORT -gt 0 ]]; then
    if [[ ! $MOODLE_DOCKER_WEB_PORT == *":"* ]]; then
        MOODLE_DOCKER_WEB_PORT=127.0.0.1:$MOODLE_DOCKER_WEB_PORT
    fi
    dockercompose+=(-f "${basedir}/webserver.port.yml")
fi

# Timeout factor
export MOODLE_DOCKER_TIMEOUT_FACTOR=${MOODLE_DOCKER_TIMEOUT_FACTOR:-1}

# Mac OS cached volumes
if [[ "$(uname)" == "Darwin" ]]; then
    dockercompose+=(-f "${basedir}/volumes-cached.yml")
fi

# Local overrides
localfile="${basedir}/local.yml"
if [ -f "$localfile" ]; then
    echo "Including local options from ${localfile}"
    dockercompose+=(-f "$localfile")
fi

# =============================
# Run the command
# =============================
"${dockercompose[@]}" "$@"